{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image Tools",
  "version": "0.1.3",
  "identifier": "com.zhoux.image-tools",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "图片工具",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "center": true,
        "dragDropEnabled": false,
        "additionalBrowserArgs": "--remote-debugging-port=9222 --disable-features=ElasticOverscroll"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
